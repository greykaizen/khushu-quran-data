[{"id":"forty_urn_1530010","urn":1530010,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"1","arabic_text":"لَیْسَ الْخَبَرُ کَالْمُعَایَنَةِ\n","translation_text":"\nThe report is not like witnessing.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 1, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530020","urn":1530020,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"2","arabic_text":"الْحَرْبُ خُدَعَةٌ\n","translation_text":"\nWar is deception.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 2, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530030","urn":1530030,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"3","arabic_text":"الْمُسْلِمُ مِرْآةُ الْمُسْلِمِ\n","translation_text":"\nA Muslim is a mirror of the Muslim.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 3, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530040","urn":1530040,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"4","arabic_text":"الْمُسْتَشَارُ مُؤتَمَنٌ\n","translation_text":"\nSomeone whose advice is sought is in a position of trust.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 4, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530050","urn":1530050,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"5","arabic_text":"الدَّالُّ عَلَی الْخَیْرِ کَفَاعِلِهِ\n","translation_text":"\nThe person guiding (someone) to do a good deed, is like the one performing the good deed.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 5, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530060","urn":1530060,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"6","arabic_text":"إِسْتَعِیْنُوْا عَلَی الْحَوَائِجِ بِالْکِتْمَانِ\n","translation_text":"\nSeek help for any needs discreetly.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 6, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530070","urn":1530070,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"7","arabic_text":"إِتَّقُوْا النَّارَ وَلَوْ بِشِقِّ تَمْرَةٍ\n","translation_text":"\nProtect yourself from the fire even with a part of a date.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 7, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530080","urn":1530080,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"8","arabic_text":"الدُّنْیَا سِجْنُ الْمُؤمِنِ وَ جَنَّةُ الْکَافِرِ\n","translation_text":"\nThe world is the believer’s prison and the disbeliever’s paradise.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 8, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530090","urn":1530090,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"9","arabic_text":"الْحَیَاءُ خَیْرٌ کُلُّهُ\n","translation_text":"\nModesty is entirely good.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 9, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530100","urn":1530100,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"10","arabic_text":"عِدَةُ الْمُؤمِنِ کَاَخْذِ الْکَفِّ\n","translation_text":"\nThe word of the believer is like seizing of the hand.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 10, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530110","urn":1530110,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"11","arabic_text":"لَا یَحِلُّ لِمُؤمِنٍ اَنْ یَّجُهْرَ أخَاهُ فَوقَ ثَلَاثَةِ أیَّامٍ\n","translation_text":"\nIt is unlawful for a believer to sever relations with his brother for more than three days.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 11, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530120","urn":1530120,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"12","arabic_text":"لَیْسَ مِنَّا مَنْ غَشَّنَا\n","translation_text":"\nHe is not one of us who cheats us.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 12, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530130","urn":1530130,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"13","arabic_text":"مَا قَلَّ وَكَفَى خَيْرٌ مِمَّا كَثُرَ وَأَلْهَى\n","translation_text":"\nA little that suffices is better than an abundance that distracts.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 13, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530140","urn":1530140,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"14","arabic_text":"الرَّاجِعُ فِيْ هِبَتِهِ کَالرَّاجِعِ فِيْ قَیْئِهِ\n","translation_text":"\nSomeone who takes back his gift is like someone who eats his vomit.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 14, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530150","urn":1530150,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"15","arabic_text":"الْبَلَاءُ مُوَکِّلٌ بِالْمَنْطِقِ\n","translation_text":"\nAffliction comes from (loose) talk.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 15, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530160","urn":1530160,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"16","arabic_text":"النَّاسُ کَأسْنَانِ الْمُشْطِ\n","translation_text":"\nPeople are like the teeth of a comb.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 16, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530170","urn":1530170,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"17","arabic_text":"الْغِنَى غِنَى النَّفْسِ\n","translation_text":"\nRichness lies in the richness of the soul.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 17, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530180","urn":1530180,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"18","arabic_text":"الْسَّعِیْدُ مَنْ وُّعِظَ بِغَیْرِهِ\n","translation_text":"\nThe felicitous person takes lessons from (the actions of) others.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 18, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530190","urn":1530190,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"19","arabic_text":"وَ إِنَّ مِنَ الشِّعْرِ لَحِکْمَةً وَاِنَّ مِنَ الْبَیَانِ لَسِحْرًا\n","translation_text":"\nIndeed, in poetry there is wisdom and in eloquence there is magic.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 19, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530200","urn":1530200,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"20","arabic_text":"عَفْوُ الْمُلُوْكِ إِبْقَاءٌ لِلْمُلْكِ\n","translation_text":"\nThe king’s pardon preserves the kingdom.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 20, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530210","urn":1530210,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"21","arabic_text":"اَلْمَرْءُ مَعَ مَنْ أَحَبَّ\n","translation_text":"\nA man will be with whom he loves.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 21, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530220","urn":1530220,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"22","arabic_text":"مَا هَلَكَ إمْرُؤٌ عَرَفَ قَدْرَهُ\n","translation_text":"\nA man who knows his worth will not be ruined.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 22, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530230","urn":1530230,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"23","arabic_text":"اَلْوَلَدُ لِلْفِرَاشِ وَ لِلْعَاهِرِ الْحَجَرُ\n","translation_text":"\nThe child belongs to the bed and stoning is for the adulterer.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 23, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530240","urn":1530240,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"24","arabic_text":"الْیَدُ الْعُلْیَا خَیْرٌ مِّنَ الْیَدِ السُّفْلَی\n","translation_text":"\nThe upper hand is superior to the lower hand.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 24, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530250","urn":1530250,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"25","arabic_text":"لَا شَکَرَ اللهَ مَنْ لَّا یَشْکُرُ النَّاسَ\n","translation_text":"\nHe does not thank Allah who does not thank people.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 25, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530260","urn":1530260,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"26","arabic_text":"حُبُّكَ الشَّيْءَ یُعْمِيْ وَ یُصِمُّ\n","translation_text":"\nYour love of something can blind and deafen (you).","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 26, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530270","urn":1530270,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"27","arabic_text":"جُبِلَتِ الْقُلُوبُ عَلی حُبَّ مَنْ اَحْسَنَ اِلَیْهَا وَ بُغْضِ مَنْ اَسَاءَ اِلَیْهَا\n","translation_text":"\nHearts are predisposed to love someone who does them good and detest someone who does them harm.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 27, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530280","urn":1530280,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"28","arabic_text":"الْتَّائِبُ مِنَ الذَّنْبِ کَمَنْ لَا ذَنْبَ لَهُ\n","translation_text":"\nOne who repents from sin is like someone without sin.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 28, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530290","urn":1530290,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"29","arabic_text":"الشَّاهِدُ یَرَی مَا لَا یَرَاهُ الْغَائِبُ\n","translation_text":"\nThe person who actually witnesses an (event) sees that which one who is absent does not.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 29, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530300","urn":1530300,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"30","arabic_text":"اِذا جَاءَکُمْ کَرِیْمُ قَوْمٍ فَاَکْرِمُوهُ\n","translation_text":"\nIf the nobleman of a people comes to you, honour him.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 30, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530310","urn":1530310,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"31","arabic_text":"الْیَمِینُ الْفَاجِرَةُ تَدَعُ الدِّیَارَ الْبَلَاقِعَ\n","translation_text":"\nFalse oaths lay waste to home (lands).","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 31, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530320","urn":1530320,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"32","arabic_text":"مَنْ قُتِلَ دُونَ مَالِهِ فَهُوَ شَهِیْدٌ\n","translation_text":"\nWhoever is killed attempting to save his property is a martyr.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 32, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530330","urn":1530330,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"33","arabic_text":"الْاَعْمَالُ بِالنِّیَّةِ\n","translation_text":"\nActions are through intentions.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 33, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530340","urn":1530340,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"34","arabic_text":"سَیِّدُ الْقَوْمِ خَادِمُهُمْ\n","translation_text":"\nThe leader of a people is their servant.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 34, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530350","urn":1530350,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"35","arabic_text":"خَیْرُ الْأُمُوْرِ أَوْسَطُهَا\n","translation_text":"\nThe best of affairs is that which is balanced.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 35, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530360","urn":1530360,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"36","arabic_text":"اَللَّهُمَّ بَارِكْ فِیْ أُمَّتِیْ فِی بُکُوْرِهَا یَوْمَ الْخَمِیْسِ\n","translation_text":"\nO Allah, bless my nation in its early rising on Thursdays!","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 36, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530370","urn":1530370,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"37","arabic_text":"کَادَ الْفَقْرُ أَنْ یَکُوْنَ کُفْرًا\n","translation_text":"\nPoverty can almost turn into disbelief.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 37, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530380","urn":1530380,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"38","arabic_text":"الْسَّفَرُ قِطْعَةٌ مِّنَ الْعَذَابِ\n","translation_text":"\nTravelling is a portion of punishment.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 38, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530390","urn":1530390,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"39","arabic_text":"خَیْرُ زَّادِ الْتَّقْوَی\n","translation_text":"\nThe best of provision is God-Consciousness (taqwa).","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 39, 40 Hadith Shah Waliullah"}],"narrators":[]},{"id":"forty_urn_1530400","urn":1530400,"collection_id":"forty","book_id":"forty_bshahwaliullah40","chapter_id":null,"number":"40","arabic_text":"الْمَجَالِسُ بِالْاَمَانَةِ\n","translation_text":"\nMeetings are under trust.","grades":[],"references":[{"type":"sunnahcom_reference","value":"Hadith 40, 40 Hadith Shah Waliullah"}],"narrators":[]}]